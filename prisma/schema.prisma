generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum JobStatus {
  NEW
  QUOTED
  WON
  COMPLETED
  REVIEW_REQUESTED
  LOST
}

enum TaskStatus {
  PENDING
  SENT
  DONE
  SKIPPED
  OVERDUE
}

enum TaskType {
  QUOTE_FOLLOW_UP
  CONFIRMATION
  REVIEW_REQUEST
  REACTIVATION
  MANUAL
}

enum Channel {
  EMAIL
  MANUAL
}

enum PlanType {
  FREE
  PRO
}

enum LeadSource {
  MANUAL
  WEBSITE
  REFERRAL
  PHONE
  WHATSAPP
  OTHER
}

enum ContactStatus {
  LEAD
  ACTIVE
  WON
  COMPLETED
  INACTIVE
  LOST
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
  TRIALING
}

// ---------- Auth.js models ----------

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  ownerName             String?
  hashedPassword        String?
  image                 String?
  quoteFollowUpDays     Int     @default(2)
  reviewRequestDays     Int     @default(1)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  contacts      Contact[]
  jobs          Job[]
  tasks         FollowUpTask[]
  templates     MessageTemplate[]
  subscription  Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Domain models ----------

model Contact {
  id          String     @id @default(cuid())
  userId      String
  fullName    String
  phone       String?
  email       String?
  companyName String?
  serviceType String?
  source          LeadSource    @default(MANUAL)
  status          ContactStatus @default(LEAD)
  lastContactedAt DateTime?
  nextActionAt    DateTime?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs  Job[]
  tasks FollowUpTask[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, status])
}

model Job {
  id             String    @id @default(cuid())
  userId         String
  contactId      String
  title          String
  description    String?   @db.Text
  estimatedValue Decimal?  @db.Decimal(12, 2)
  currency       String    @default("USD")
  status         JobStatus @default(NEW)
  quoteSentAt    DateTime?
  wonAt          DateTime?
  completedAt    DateTime?
  lostAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tasks   FollowUpTask[]

  @@index([userId])
  @@index([contactId])
  @@index([userId, status])
  @@index([userId, status, createdAt])
}

model FollowUpTask {
  id             String     @id @default(cuid())
  userId         String
  contactId      String
  jobId          String?
  type           TaskType
  title          String
  messagePreview String?    @db.Text
  dueDate        DateTime
  status         TaskStatus @default(PENDING)
  channel        Channel    @default(EMAIL)
  autoGenerated  Boolean    @default(false)
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  job     Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contactId])
  @@index([jobId])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, status, dueDate])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  userId    String
  type      TaskType
  name      String
  subject   String
  body      String   @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 PlanType           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
